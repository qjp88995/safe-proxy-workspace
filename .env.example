# Copy this file to .env and replace the sample values.

IMAGE_NAME=safe-proxy-workspace:latest
CONTAINER_NAME=safe-proxy-workspace
DESKTOP_IMAGE_NAME=safe-proxy-workspace-desktop:latest
DESKTOP_CONTAINER_NAME=safe-proxy-workspace-desktop

# Local runtime config (should stay untracked)
MIHOMO_CONFIG_PATH=./config.yaml

# The TUN device name must match config.yaml/config.example.yaml.
TUN_DEVICE=Mihomo

# These endpoints must match:
# 1. proxies[*].server:port in config.yaml
# 2. tun.route-exclude-address in config.yaml
DIRECT_ALLOWLIST_TCP=203.0.113.10:8388,198.51.100.20:8388
DIRECT_ALLOWLIST_UDP=203.0.113.10:8388,198.51.100.20:8388

# Long-lived workspace mount
WORKSPACE_MOUNT=.
WORKSPACE_USER=workspace

# Desktop/VNC variant (used by the workspace-desktop profile)
DESKTOP_VNC_BIND=127.0.0.1
DESKTOP_VNC_PORT=5901
VNC_PASSWORD=replace-this-before-use
VNC_GEOMETRY=1440x900
VNC_DEPTH=24
