# Copy this file to .env and replace the sample values.

# Desktop/VNC image by default. For CLI-only mode, switch IMAGE_NAME to
# ghcr.io/qjp88995/safe-proxy-workspace:latest and set DESKTOP_MODE=0.
IMAGE_NAME=ghcr.io/qjp88995/safe-proxy-workspace-desktop:latest
CONTAINER_NAME=safe-proxy-workspace

# Local runtime config (should stay untracked)
MIHOMO_CONFIG_PATH=./config.yaml

# The TUN device name must match config.yaml.
TUN_DEVICE=Mihomo

# These endpoints must match:
# 1. proxies[*].server:port in config.yaml
# 2. tun.route-exclude-address in config.yaml
DIRECT_ALLOWLIST_TCP=203.0.113.10:8388,198.51.100.20:8388
DIRECT_ALLOWLIST_UDP=203.0.113.10:8388,198.51.100.20:8388

# Optional extra direct CIDRs. Attached Docker bridge subnets are detected automatically,
# so you usually only need this for additional private networks.
DIRECT_ALLOWLIST_SUBNETS=

# Absolute path on the host that should appear inside the container at ~/workspace.
WORKSPACE_MOUNT=/absolute/path/to/your/workspace

# Controls the in-container username, home directory (/home/<name>), and workspace path.
WORKSPACE_USER=workspace

# Desktop/VNC mode
DESKTOP_MODE=1
DESKTOP_VNC_BIND=127.0.0.1
DESKTOP_VNC_PORT=5901
VNC_PASSWORD=replace-this-before-use
VNC_GEOMETRY=1440x900
VNC_DEPTH=24
DESKTOP_SHM_SIZE=2gb
